PROJECT_NAME=VoltPulse Analytics
ENVIRONMENT=local

POSTGRES_DB=voltpulse
POSTGRES_USER=voltpulse
POSTGRES_PASSWORD=voltpulse_dev_password
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

REDIS_PASSWORD=redis_dev_password
REDIS_HOST=redis
REDIS_PORT=6379

MQTT_USERNAME=voltpulse_mqtt
MQTT_PASSWORD=mqtt_dev_password
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_METRICS_TOPIC=voltpulse/+/devices/+/metrics

NILM_ANOMALY_DETECTION_ENABLED=true
NILM_ANOMALY_MIN_STEP_W=500
NILM_ANOMALY_LOOKBACK_SAMPLES=96
NILM_ANOMALY_FRESHNESS_SECONDS=300
NILM_ANOMALY_DUPLICATE_WINDOW_SECONDS=600
NILM_DATASETS_DIR=/absolute/path/to/local/nilm/datasets

JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

FRONTEND_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173","http://127.0.0.1:5174","http://localhost:5174","http://127.0.0.1:5175","http://localhost:5175"]
